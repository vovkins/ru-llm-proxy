# === LLM Provider Keys ===
ZAI_API_KEY=***
OPENAI_API_KEY=***
ANTHROPIC_API_KEY=***
GOOGLE_API_KEY=***

# === LiteLLM ===
LITELLM_MASTER_KEY=sk-replace-with-generated-key
LITELLM_SALT_KEY=replace-with-generated-salt
LITELLM_PORT=4000
LITELLM_DB_URL=postgresql://litellm:litellm@db:5432/litellm

# === Presidio (internal URLs) ===
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:5001
PII_GUARDRAIL_FAILURE_MODE=fail_open
PII_MAPPING_TTL_SECONDS=3600

# === Build-time DeepPavlov model download ===
DEEPPAVLOV_NER_MODEL_URL=http://files.deeppavlov.ai/v1/ner/ner_rus_bert_torch_new.tar.gz
DEEPPAVLOV_NER_MODEL_SHA256=
DEEPPAVLOV_NER_DOWNLOAD_TIMEOUT_SECONDS=120

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# === PostgreSQL ===
POSTGRES_USER=litellm
POSTGRES_PASSWORD=***
POSTGRES_DB=litellm
