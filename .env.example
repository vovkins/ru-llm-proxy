# === LLM Provider Keys ===
ZAI_API_KEY=***
# Optional second account key. It is inert until litellm-config.yaml adds a second deployment.
ZAI_API_KEY_2=
OPENAI_API_KEY=***
ANTHROPIC_API_KEY=***

# === LiteLLM ===
LITELLM_MASTER_KEY=sk-replace-with-generated-key
LITELLM_SALT_KEY=replace-with-generated-salt
# Optional virtual key for routing smoke tests. Falls back to LITELLM_MASTER_KEY.
LITELLM_ROUTING_TEST_KEY=
# Optional live-validated proxy aliases for strict client-auth smoke.
RESPONSES_MODEL=
MESSAGES_MODEL=
LITELLM_PORT=4000
LITELLM_DB_URL=postgresql://litellm:litellm@db:5432/litellm

# === Optional JWT/OIDC proxy auth (requires LiteLLM Enterprise) ===
# JWT_PUBLIC_KEY_URL=https://idp.example.com/.well-known/jwks.json
# JWT_AUDIENCE=ru-llm-proxy

# === LiteLLM Admin UI ===
UI_USERNAME=admin
UI_PASSWORD=replace-with-generated-ui-password

# === Presidio (internal URLs) ===
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:5001
PII_GUARDRAIL_FAILURE_MODE=fail_open
PII_MAPPING_TTL_SECONDS=3600

# === Build-time DeepPavlov model download ===
DEEPPAVLOV_NER_MODEL_URL=http://files.deeppavlov.ai/v1/ner/ner_rus_bert_torch_new.tar.gz
DEEPPAVLOV_NER_MODEL_SHA256=
DEEPPAVLOV_NER_DOWNLOAD_TIMEOUT_SECONDS=120

# === Redis ===
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# === PostgreSQL ===
POSTGRES_USER=litellm
POSTGRES_PASSWORD=***
POSTGRES_DB=litellm
